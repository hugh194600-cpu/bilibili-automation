/* pages/signin/signin.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 未登录状态 */
.not-login {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.not-login-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  width: 80%;
}

.not-login-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.not-login-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.not-login-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 签到主体 */
.signin-content {
  padding-bottom: 40rpx;
}

/* 日历卡片 */
.calendar-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.month-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #00A0E9;
  margin-right: 16rpx;
}

.year-text {
  font-size: 28rpx;
  color: #999;
}

.calendar-week {
  display: flex;
  margin-bottom: 16rpx;
}

.week-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
}

.day-item {
  width: 14.28%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-text {
  font-size: 28rpx;
  color: #333;
}

.day-item.today .day-text {
  color: #00A0E9;
  font-weight: 600;
}

.day-item.signed .day-text {
  color: #999;
}

.sign-mark {
  width: 16rpx;
  height: 16rpx;
  background: #52c41a;
  border-radius: 50%;
  position: absolute;
  bottom: 10rpx;
}

.day-item.today .sign-mark {
  background: #00A0E9;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.text-success {
  color: #52c41a !important;
}

.text-warning {
  color: #fa8c16 !important;
}

/* 签到按钮 */
.signin-btn-area {
  margin-bottom: 30rpx;
}

.btn-signin {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.btn-active {
  background: linear-gradient(135deg, #00A0E9 0%, #0080DC 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 160, 233, 0.4);
}

.btn-active:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-disabled {
  background: #f0f0f0;
  color: #999;
  box-shadow: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 奖励卡片 */
.reward-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title .icon {
  margin-right: 12rpx;
}

.reward-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.reward-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.reward-day {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.reward-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #00A0E9;
}

/* 记录卡片 */
.log-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.log-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.log-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.log-item:last-child {
  border-bottom: none;
}

.log-date {
  font-size: 26rpx;
  color: #666;
}

.log-reward {
  font-size: 26rpx;
  color: #52c41a;
  font-weight: 500;
}

.empty-log {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 60rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #00A0E9 0%, #0080DC 100%);
  color: #fff;
}
