/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 未登录状态 */
.not-login {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.not-login-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  width: 80%;
}

.not-login-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.not-login-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.not-login-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 60rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #00A0E9 0%, #0080DC 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 160, 233, 0.3);
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #00A0E9 0%, #0080DC 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 160, 233, 0.3);
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 20rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-meta {
  display: flex;
  align-items: center;
}

.user-level {
  font-size: 22rpx;
  color: #FFD700;
  background: rgba(0, 0, 0, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.user-uid {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.btn-logout {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

/* 状态网格 */
.status-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.status-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.status-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  display: inline-block;
}

.status-icon.pulse {
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

.status-title {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.status-value {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}

.text-success { color: #52c41a; }
.text-warning { color: #fa8c16; }
.text-gray { color: #999; }

.status-days {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 快捷操作 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title .icon {
  margin-right: 12rpx;
}

.action-list {
  border-top: 1rpx solid #f0f0f0;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.action-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.action-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 任务日志 */
.log-list {
  max-height: 300rpx;
  overflow-y: auto;
}

.log-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 24rpx;
}

.log-item:last-child {
  border-bottom: none;
}

.log-time {
  color: #999;
  margin-right: 16rpx;
  white-space: nowrap;
}

.log-content {
  color: #666;
  flex: 1;
}
