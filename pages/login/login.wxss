/* pages/login/login.wxss */

.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #00A0E9 0%, #f5f5f5 30%);
}

/* Logo区域 */
.logo-area {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 30rpx;
  background: #fff;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 160, 233, 0.3);
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
}

.app-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.app-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title .icon {
  margin-right: 12rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.step-title {
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.mt-20 {
  margin-top: 30rpx;
}

/* 输入框 */
.input-group {
  margin-bottom: 20rpx;
}

.cookie-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  font-size: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  box-sizing: border-box;
}

.cookie-input:focus {
  border-color: #00A0E9;
  background: #fff;
}

.placeholder {
  color: #999;
}

/* 提示 */
.tips {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background: #fffbe6;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #fa8c16;
}

.tips-icon {
  margin-right: 8rpx;
}

/* 用户协议 */
.agreement {
  margin: 30rpx 0;
}

.checkbox-label {
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement-text {
  font-size: 26rpx;
  color: #666;
  margin-left: 12rpx;
}

.link {
  font-size: 26rpx;
  color: #00A0E9;
  margin-left: 8rpx;
}

/* 按钮区域 */
.btn-area {
  margin-top: 40rpx;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-primary {
  background: linear-gradient(135deg, #00A0E9 0%, #0080DC 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 160, 233, 0.4);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-primary[disabled] {
  background: #ccc;
  box-shadow: none;
}

/* 测试提示 */
.test-tip {
  text-align: center;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
}
