/* pages/mine/mine.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户区域 */
.user-area {
  position: relative;
  margin-bottom: 20rpx;
}

.user-bg {
  height: 240rpx;
  background: linear-gradient(135deg, #00A0E9 0%, #0080DC 100%);
}

.user-card {
  position: absolute;
  top: 140rpx;
  left: 30rpx;
  right: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.login-tip {
  color: #999;
}

.login-desc {
  font-size: 24rpx;
  color: #999;
}

.user-meta {
  display: flex;
  align-items: center;
}

.user-level {
  font-size: 22rpx;
  color: #FFD700;
  background: rgba(255, 215, 0, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.user-uid {
  font-size: 24rpx;
  color: #999;
}

/* 菜单区域 */
.menu-area {
  background: #fff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-top: 100rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.cache-size {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.menu-divider {
  height: 16rpx;
  background: #f5f5f5;
}

/* 数据统计 */
.stats-area {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #00A0E9;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
}

/* 使用说明 */
.guide-area {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.guide-content {
  display: flex;
  flex-direction: column;
}

.guide-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.guide-num {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #00A0E9 0%, #0080DC 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.guide-text {
  font-size: 26rpx;
  color: #666;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #999;
}

.version-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
}
